-- Teleport checkpoints 1-60 to you, jump until stage 60, then rebirth and rejoin

local player = game.Players.LocalPlayer
local character = player.Character
local hrp = character and character:FindFirstChild("HumanoidRootPart")
local humanoid = character and character:FindFirstChild("Humanoid")
local TeleportService = game:GetService("TeleportService")

if not hrp or not humanoid then
    warn("Character, HumanoidRootPart, or Humanoid not found")
    return
end

local targetPos = hrp.Position

-- Teleport all checkpoints 1-60 to your position
for i = 1, 60 do
    local checkpoint = workspace:FindFirstChild("Checkpoints") 
        and workspace.Checkpoints:FindFirstChild(tostring(i)) 
        and workspace.Checkpoints[tostring(i)]:FindFirstChild("Checkpoint")
    
    if checkpoint and checkpoint:IsA("BasePart") then
        pcall(function()
            checkpoint.CFrame = CFrame.new(targetPos + Vector3.new(0, 0, -3))
        end)
    end
end

print("Teleported checkpoints 1-60 to your position")

-- Get current stage value
local function getCurrentStage()
    local stageGui = player.PlayerGui:FindFirstChild("MainUI")
    if not stageGui then return 0 end
    
    local stageSelector = stageGui:FindFirstChild("StageSelector")
    if not stageSelector then return 0 end
    
    local container = stageSelector:FindFirstChild("Container")
    if not container then return 0 end
    
    local stage = container:FindFirstChild("Stage")
    if not stage then return 0 end
    
    if stage:IsA("TextLabel") or stage:IsA("TextBox") then
        local num = tonumber(stage.Text)
        if num then return num end
    end
    
    return 0
end

local function fireRebirth()
    pcall(function()
        local args = {}
        game:GetService("ReplicatedStorage"):WaitForChild("Signals"):WaitForChild("Rebirth"):FireServer(unpack(args))
    end)
    print("Rebirth fired")
end

local function rejoinGame()
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    print("Rejoining...")
end

-- Jump loop with ground check
task.spawn(function()
    while true do
        local currentStage = getCurrentStage()
        if currentStage >= 60 then
            print("Stage " .. currentStage .. " reached! Stopping jump.")
            
            -- Fire rebirth
            task.wait(1)
            fireRebirth()
            
            -- Rejoin game
            task.wait(1)
            rejoinGame()
            
            break
        end
        
        -- Only jump if on ground
        if humanoid and humanoid.FloorMaterial ~= Enum.Material.Air then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        
        task.wait(0.3)
    end
end)

print("Jumping until stage 60, then rebirth and rejoin")
