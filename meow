task.wait(1)

-- Teleport through checkpoints 1-60, then rebirth, then rejoin

local player = game.Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

local function teleportToCheckpoint(num)
    local checkpoint = workspace:FindFirstChild("Checkpoints") 
        and workspace.Checkpoints:FindFirstChild(tostring(num)) 
        and workspace.Checkpoints[tostring(num)]:FindFirstChild("Base")
    
    if not checkpoint then
        warn("Checkpoint " .. num .. " not found")
        return false
    end
    
    local character = player.Character
    if not character then return false end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    hrp.CFrame = CFrame.new(checkpoint.Position + Vector3.new(0, 3, 0))
    return true
end

local function fireRebirth()
    local args = {}
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("Signals"):WaitForChild("Rebirth"):FireServer(unpack(args))
    end)
    print("Rebirth fired")
end

local function rejoinGame()
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    print("Rejoining...")
end

-- Main sequence
task.spawn(function()
    -- Teleport through checkpoints 1 to 60
    for i = 1, 60 do
        print("Teleporting to checkpoint " .. i)
        teleportToCheckpoint(i)
        task.wait(0.1)
    end
    
    -- Fire rebirth
    task.wait()
    fireRebirth(0.5)
    
    -- Rejoin game
    task.wait()
    rejoinGame(0.5)
end)

print("Starting checkpoint teleport (1-60) → Rebirth → Rejoin")
