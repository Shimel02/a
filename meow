-- Teleport checkpoints 1-60 to you, jump until stage 60, then rebirth and rejoin
-- Autoexec compatible - waits indefinitely for everything to load

local player = game.Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

local function waitForCharacter()
    while true do
        local char = player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and hum then
                return char, hrp, hum
            end
        end
        task.wait(0.5)
    end
end

local function waitForUI()
    while true do
        local stageGui = player.PlayerGui:FindFirstChild("MainUI")
        if stageGui then
            local stageSelector = stageGui:FindFirstChild("StageSelector")
            if stageSelector then
                local container = stageSelector:FindFirstChild("Container")
                if container then
                    local stage = container:FindFirstChild("Stage")
                    if stage then
                        return stage
                    end
                end
            end
        end
        task.wait(0.5)
    end
end

local function teleportCheckpoints(hrp)
    if not hrp then return end
    local targetPos = hrp.Position
    
    for i = 1, 60 do
        local checkpoint = workspace:FindFirstChild("Checkpoints")
        if checkpoint then
            local numFolder = checkpoint:FindFirstChild(tostring(i))
            if numFolder then
                local checkpointPart = numFolder:FindFirstChild("Checkpoint")
                if checkpointPart and checkpointPart:IsA("BasePart") then
                    pcall(function()
                        checkpointPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 0, -3))
                    end)
                end
            end
        end
        task.wait(0.05)
    end
    print("Teleported checkpoints 1-60")
end

local function fireRebirth()
    pcall(function()
        local reb = game:GetService("ReplicatedStorage"):FindFirstChild("Signals")
        if reb then
            local rebirth = reb:FindFirstChild("Rebirth")
            if rebirth then
                rebirth:FireServer()
            end
        end
    end)
    print("Rebirth fired")
end

local function rejoinGame()
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    print("Rejoining...")
end

-- Wait for everything
print("Waiting for character...")
local char, hrp, hum = waitForCharacter()
print("Character loaded")

print("Waiting for UI...")
local stage = waitForUI()
print("UI loaded")

-- Wait a bit more for world to settle
task.wait(2)

-- Teleport checkpoints
teleportCheckpoints(hrp)

-- Jump until stage 60
local jumping = true
task.spawn(function()
    while jumping do
        local currentNum = tonumber(stage.Text)
        if currentNum and currentNum >= 60 then
            print("Stage " .. currentNum .. " reached!")
            jumping = false
            
            task.wait(1)
            fireRebirth()
            
            task.wait(1)
            rejoinGame()
            break
        end
        
        -- Refresh humanoid and jump
        local currentChar = player.Character
        if currentChar then
            local currentHum = currentChar:FindFirstChild("Humanoid")
            if currentHum and currentHum.FloorMaterial ~= Enum.Material.Air then
                currentHum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        
        task.wait(0.2)
    end
end)

print("Script running - waiting for stage 60...")
