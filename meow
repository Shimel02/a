-- Teleport checkpoints 1-60 to you, jump until stage 60, then rebirth and rejoin
-- Waits for character and UI to load before starting

local player = game.Players.LocalPlayer
local TeleportService = game:GetService("TeleportService")

-- Wait for character to load
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

-- Wait for UI to load
local stageGui = player.PlayerGui:WaitForChild("MainUI")
local stageSelector = stageGui:WaitForChild("StageSelector")
local container = stageSelector:WaitForChild("Container")
local stage = container:WaitForChild("Stage")

print("Character and UI loaded! Starting script...")

-- Function to teleport checkpoints (gets fresh position each time)
local function teleportCheckpoints()
    -- Get current character position fresh
    local currentChar = player.Character
    if not currentChar then return end
    
    local currentHrp = currentChar:FindFirstChild("HumanoidRootPart")
    if not currentHrp then return end
    
    local targetPos = currentHrp.Position
    
    for i = 1, 60 do
        local checkpoint = workspace:FindFirstChild("Checkpoints") 
            and workspace.Checkpoints:FindFirstChild(tostring(i)) 
            and workspace.Checkpoints[tostring(i)]:FindFirstChild("Checkpoint")
        
        if checkpoint and checkpoint:IsA("BasePart") then
            pcall(function()
                checkpoint.CFrame = CFrame.new(targetPos + Vector3.new(0, 0, -3))
            end)
        end
    end
    
    print("Teleported checkpoints 1-60 to your position")
end

-- Wait additional 2 seconds for world to fully stabilize
task.wait(2)

-- Teleport checkpoints
teleportCheckpoints()

-- Get current stage value
local function getCurrentStage()
    if not stage or not stage.Parent then return 0 end
    local num = tonumber(stage.Text)
    return num or 0
end

local function fireRebirth()
    pcall(function()
        local args = {}
        game:GetService("ReplicatedStorage"):WaitForChild("Signals"):WaitForChild("Rebirth"):FireServer(unpack(args))
    end)
    print("Rebirth fired")
end

local function rejoinGame()
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    print("Rejoining...")
end

-- Jump loop with ground check
task.spawn(function()
    while true do
        local currentStage = getCurrentStage()
        if currentStage >= 60 then
            print("Stage " .. currentStage .. " reached! Stopping jump.")
            
            -- Fire rebirth
            task.wait(1)
            fireRebirth()
            
            -- Rejoin game
            task.wait(1)
            rejoinGame()
            
            break
        end
        
        -- Only jump if on ground
        if humanoid and humanoid.FloorMaterial ~= Enum.Material.Air then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
        
        task.wait(0.3)
    end
end)

print("Jumping until stage 60, then rebirth and rejoin")
